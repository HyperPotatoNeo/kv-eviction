__pycache__/
*.pyc
*.egg-info/
.venv/
experiments/eval/results/
experiments/phase3_kl_test/results/
experiments/phase3_preprod/results/
/textworld_cooking_mix
# Training output directories (written by smoke runs, large, transient)
outputs/
*.json

# Minimal stub uv.lock — not a real lockfile, regenerated by `uv sync`
uv.lock

# Per-job launcher artifacts: each SLURM job id produces its own
# resolved TOML and per-role logs. Keep the TOML templates
# (rl_*.toml, inference_*.toml) and launcher scripts (*.sh) in git;
# ignore everything produced at runtime.
experiments/*/resolved_*.toml
experiments/*/trainer_*.log
experiments/*/inference*.log
experiments/*/launch_*.log
experiments/*/setup_*.log
experiments/*/rebuild_*.log
experiments/*/slurm_*.out
experiments/*/slurm_*.err

# Ad-hoc diagnostic logs from the phase3_kl_test investigations
experiments/phase3_kl_test/compare_modes_*.log

# Local cluster-specific README (NERSC Perlmutter setup notes with
# absolute paths, SLURM account codes, podman-hpc invocation, etc.).
# The tracked README.md has cluster-agnostic instructions.
README.cluster.md

# Per-directory wandb config (see .envrc) — local API key + settings.
.netrc
.wandb-config/
.env

# Local debugging/testbed archives; intentionally not committed.
.local_artifacts/
